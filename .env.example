# Alpaca paper keys are safe to start with. Do not commit real keys.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Required by SEC fair-access guidance. Use your email.
SEC_USER_AGENT="trading-agent your-email@example.com"

# Leave false until you have tested in paper and understand the risks.
ALLOW_LIVE_TRADING=false
